{
  "name": "song-translator",
  "version": "0.2.1",
  "description": "CLI para traduzir musicas japonesas e gerar PDFs em romaji e portugues.",
  "type": "module",
  "bin": {
    "song-translator": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "dev": "tsx src/cli.tsx",
    "start": "node dist/cli.js",
    "test": "npm run build",
    "prepack": "npm run build"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@inquirer/prompts": "^7.8.0",
    "cheerio": "^1.1.2",
    "dotenv": "^17.2.3",
    "ink": "^6.3.1",
    "ink-gradient": "^3.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "kuroshiro": "^1.2.0",
    "kuroshiro-analyzer-kuromoji": "^1.1.0",
    "openai": "^6.9.1",
    "pdfkit": "^0.17.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/pdfkit": "^0.17.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gustavohiroaki/song-translator.git"
  }
}
